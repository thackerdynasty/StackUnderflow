@model StackUnderflow.Models.SUThread

@{
    ViewData["Title"] = "Delete Thread";
}

<div class="container">
    <div class="row justify-content-center">
        <div class="col-md-6">
            <div class="card mt-4 border-danger">
                <div class="card-header bg-danger text-white">
                    <h2 class="mb-0">Confirm Delete</h2>
                </div>
                <div class="card-body">
                    <p>Are you sure you want to delete the following thread?</p>
                    <h5 class="card-title">@Model.Title</h5>
                    <p class="text-muted small">Created: @Model.CreatedAt.ToString("MMM d, yyyy")</p>

                    <form asp-action="Delete" asp-route-id="@Model.Id" method="post">
                        @Html.AntiForgeryToken()
                        <div class="d-flex gap-2">
                            <button type="submit" class="btn btn-danger">Delete</button>
                            <a asp-action="Detail" asp-route-id="@Model.Id" class="btn btn-secondary">Cancel</a>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>
