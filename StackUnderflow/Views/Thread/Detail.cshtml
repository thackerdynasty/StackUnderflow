@using System.Security.Claims
@using StackUnderflow.Utilities
@model SUThread

@{
    ViewData["Title"] = Model.Title;
    var questionScore = Model.UpvoteCount - Model.DownvoteCount;
    var answerCount = Model.Posts?.Count ?? 0;
    var authorName = Model.User?.UserName ?? "unknown user";
    var questionVote = ViewBag.QuestionVote is int currentQuestionVote ? currentQuestionVote : 0;
    var answerVotes = ViewBag.AnswerVotes as IDictionary<int, int> ?? new Dictionary<int, int>();
    var selectedSort = Context.Request.Query["sort"].ToString();
    var editPostId = int.TryParse(Context.Request.Query["editPostId"], out var requestedPostEditId)
        ? requestedPostEditId
        : (int?)null;
    var editCommentId = int.TryParse(Context.Request.Query["editCommentId"], out var requestedCommentEditId)
        ? requestedCommentEditId
        : (int?)null;
    var currentUserId = User.FindFirst(ClaimTypes.NameIdentifier)?.Value;

    var postsQuery = (Model.Posts ?? Array.Empty<Post>())
        .OrderByDescending(post => post.IsAcceptedAnswer);

    var posts = selectedSort switch
    {
        "newest" => postsQuery.ThenByDescending(post => post.CreatedAt).ToList(),
        "oldest" => postsQuery.ThenBy(post => post.CreatedAt).ToList(),
        _ => postsQuery
            .ThenByDescending(post => post.Upvotes - post.Downvotes)
            .ThenBy(post => post.CreatedAt)
            .ToList()
    };
    
    bool isThreadOwner = User.Identity?.IsAuthenticated == true && Model.UserId == currentUserId;
}

<section class="thread-detail">
    <header class="thread-header">
        <div>
            <h1>@Model.Title</h1>
            <div class="thread-facts">
                <span>Asked @Model.CreatedAt.ToString("MMM d, yyyy")</span>
                <span>Modified @Model.UpdatedAt.ToString("MMM d, yyyy")</span>
                <span>Viewed @Model.ViewCount @(Model.ViewCount == 1 ? "time" : "times")</span>
            </div>
        </div>
    </header>

    <article class="thread-post">
        <aside class="vote-column" aria-label="Question score">
            <form asp-controller="Thread" asp-action="VoteQuestion" asp-route-id="@Model.Id" method="post" class="vote-form">
                @if (isThreadOwner)
                {
                    <button type="submit" name="vote" value="up" class="vote-control @(questionVote == 1 ? "is-selected" : "")" aria-label="Upvote question" disabled>▲</button>
                }
                else
                {
                    <button type="submit" name="vote" value="up" class="vote-control @(questionVote == 1 ? "is-selected" : "")" aria-label="Upvote question">▲</button>
                }
            </form>
            <strong>@questionScore</strong>
            <form asp-controller="Thread" asp-action="VoteQuestion" asp-route-id="@Model.Id" method="post" class="vote-form">
                @if (isThreadOwner)
                {
                    <button type="submit" name="vote" value="down" class="vote-control @(questionVote == -1 ? "is-selected" : "")" aria-label="Downvote question" disabled>▼</button>
                }
                else
                {
                    <button type="submit" name="vote" value="down" class="vote-control @(questionVote == -1 ? "is-selected" : "")" aria-label="Downvote question">▼</button>
                }
            </form>
            @if (Model.IsSolved)
            {
                <div class="accepted-mark" title="Solved" aria-label="Solved">✓</div>
            }
        </aside>

        <div class="post-body">
            <div class="post-content">@Html.Raw(ContentParser.RenderCodeBlocks(Model.Content))</div>

            <footer class="post-footer">
                <div class="post-actions">
					@if (isThreadOwner)
                    {
                        <a asp-controller="Thread" asp-action="Edit" asp-route-id="@Model.Id">Edit</a>
                        <a asp-controller="Thread" asp-action="Delete" asp-route-id="@Model.Id">Delete</a>
                    }
                </div>

                <div class="user-card">
                    <span>asked @Model.CreatedAt.ToString("MMM d, yyyy")</span>
                    <a asp-controller="Profile" asp-action="Details" asp-route-id="@Model.UserId"><strong>@authorName</strong></a>
                    <span>@(Model.User?.Reputation ?? 0) reputation</span>
                </div>
            </footer>
        </div>
    </article>

    <section class="answers-section">
        <div class="answers-header">
            <h2>@answerCount @(answerCount == 1 ? "Answer" : "Answers")</h2>
            <form method="get">
                <select name="sort" class="form-select answer-sort" aria-label="Answer sort order" onchange="this.form.submit()">
                    <option value="score" selected="@(selectedSort != "newest" && selectedSort != "oldest")">Highest score</option>
                    <option value="newest" selected="@(selectedSort == "newest")">Newest</option>
                    <option value="oldest" selected="@(selectedSort == "oldest")">Oldest</option>
                </select>
            </form>
        </div>

        @if (posts.Count == 0)
        {
            <div class="empty-answers">
                <h3>No answers yet</h3>
                <p>Be the first to respond with a clear explanation or working solution.</p>
            </div>
        }
        else
        {
            foreach (var post in posts)
            {
                var answerScore = post.Upvotes - post.Downvotes;
                var postAuthorName = post.User?.UserName ?? "unknown user";
                var isAnswerOwner = User.Identity?.IsAuthenticated == true && post.UserId == currentUserId;
                var answerVote = answerVotes.TryGetValue(post.Id, out var currentAnswerVote) ? currentAnswerVote : 0;
                var comments = (post.Comments ?? Array.Empty<Comment>())
                    .OrderBy(comment => comment.CreatedAt)
                    .ToList();

                <article id="answer-@post.Id" class="thread-post answer-post @(post.IsAcceptedAnswer ? "accepted-answer" : "")" style="scroll-margin-top: 1rem;">
                    <aside class="vote-column" aria-label="Answer score">
                        <form asp-controller="Thread" asp-action="VoteAnswer" asp-route-threadId="@Model.Id" asp-route-postId="@post.Id" method="post" class="vote-form">
                            @if (isAnswerOwner)
                            {
                                <button type="submit" name="vote" value="up" class="vote-control @(answerVote == 1 ? "is-selected" : "")" aria-label="Upvote answer" disabled>▲</button>
                            }
                            else
                            {
                                <button type="submit" name="vote" value="up" class="vote-control @(answerVote == 1 ? "is-selected" : "")" aria-label="Upvote answer">▲</button>
                            }
                        </form>
                        <strong>@answerScore</strong>
                        <form asp-controller="Thread" asp-action="VoteAnswer" asp-route-threadId="@Model.Id" asp-route-postId="@post.Id" method="post" class="vote-form">
                            @if (isAnswerOwner)
                            {
                                <button type="submit" name="vote" value="down" class="vote-control @(answerVote == -1 ? "is-selected" : "")" aria-label="Downvote answer" disabled>▼</button>
                            }
                            else
                            {
                                <button type="submit" name="vote" value="down" class="vote-control @(answerVote == -1 ? "is-selected" : "")" aria-label="Downvote answer">▼</button>
                            }
                        </form>
                        @if (post.IsAcceptedAnswer)
                        {
                            <div class="accepted-mark" title="Accepted answer" aria-label="Accepted answer">✓</div>
                        }
                    </aside>

                    <div class="post-body">
                        @if (editPostId == post.Id && isAnswerOwner)
                        {
                            <form asp-controller="Thread" asp-action="EditAnswer" asp-route-threadId="@Model.Id" asp-route-postId="@post.Id" method="post" class="inline-edit-form">
                                @if (TempData["PostEditError"] is string postEditError)
                                {
                                    <div class="text-danger answer-error">@postEditError</div>
                                }
                                <label for="post-edit-@post.Id" class="form-label">Edit your answer</label>
                                <textarea id="post-edit-@post.Id" name="content" class="form-control" rows="8">@post.Content</textarea>
                                <div class="inline-edit-actions">
                                    <button type="submit" class="btn btn-primary btn-sm">Save</button>
                                    <a asp-controller="Thread" asp-action="Detail" asp-route-id="@Model.Id" asp-fragment="answer-@post.Id" class="btn btn-secondary btn-sm">Cancel</a>
                                </div>
                            </form>
                        }
                        else
                        {
                            <div class="post-content">@Html.Raw(ContentParser.RenderCodeBlocks(post.Content))</div>
                        }
                        
                        <footer class="post-footer">
                            <div class="post-actions">
                                @if (isAnswerOwner)
                                {
                                    <a asp-controller="Thread" asp-action="Detail" asp-route-id="@Model.Id" asp-route-editPostId="@post.Id" asp-fragment="answer-@post.Id">Edit</a>
                                    <form asp-controller="Thread" asp-action="DeleteAnswer" asp-route-threadId="@Model.Id" asp-route-postId="@post.Id" method="post" class="link-form">
                                        <button type="submit" onclick="return confirm('Delete this answer?');">Delete</button>
                                    </form>
                                }
                            </div>

                            <div class="user-card">
                                <span>answered @post.CreatedAt.ToString("MMM d, yyyy")</span>
                                <a asp-controller="Profile" asp-action="Details" asp-route-id="@post.UserId"><strong>@postAuthorName</strong></a>
                                <span>@(post.User?.Reputation ?? 0) reputation</span>
                            </div>
                        </footer>
                        
                        @if (isThreadOwner && !post.IsAcceptedAnswer && !Model.IsSolved)
                        {
                            <form asp-controller="Thread" asp-action="AcceptAnswer" asp-route-id="@Model.Id" asp-route-postId="@post.Id" method="post">
                                <button type="submit" 
                                        class="btn btn-primary" 
                                        style="background-color: green; outline-color: green; border-color: green;"
                                        title="Mark as accepted answer" 
                                        aria-label="Mark as accepted answer">Accept Answer</button>
                            </form>
                        }
                     
                        <div class="comment-list">
                            @foreach (var comment in comments)
                            {
                                var isCommentOwner = User.Identity?.IsAuthenticated == true && comment.UserId == currentUserId;
                                <div id="comment-@comment.Id" class="comment" style="scroll-margin-top: 1rem;">
                                    @if (editCommentId == comment.Id && isCommentOwner)
                                    {
                                        <form asp-controller="Thread" asp-action="EditComment" asp-route-threadId="@Model.Id" asp-route-commentId="@comment.Id" method="post" class="inline-comment-edit-form">
                                            @if (TempData["CommentEditError"] is string commentEditError)
                                            {
                                                <div class="text-danger answer-error">@commentEditError</div>
                                            }
                                            <label for="comment-edit-@comment.Id" class="visually-hidden">Edit comment</label>
                                            <textarea id="comment-edit-@comment.Id" name="content" class="form-control form-control-sm" rows="3">@comment.Content</textarea>
                                            <div class="inline-edit-actions">
                                                <button type="submit" class="btn btn-primary btn-sm">Save</button>
                                                <a asp-controller="Thread" asp-action="Detail" asp-route-id="@Model.Id" asp-fragment="comment-@comment.Id" class="btn btn-secondary btn-sm">Cancel</a>
                                            </div>
                                        </form>
                                    }
                                    else
                                    {
                                        <span>@comment.Content</span>
                                        <span class="comment-meta">- <a asp-controller="Profile" asp-action="Details" asp-route-id="@comment.UserId">@(comment.User?.UserName ?? "unknown user")</a> @comment.CreatedAt.ToString("MMM d, yyyy")</span>
                                        @if (isCommentOwner)
                                        {
                                            <span class="comment-actions">
                                                <a asp-controller="Thread" asp-action="Detail" asp-route-id="@Model.Id" asp-route-editCommentId="@comment.Id" asp-fragment="comment-@comment.Id">Edit</a>
                                                <form asp-controller="Thread" asp-action="DeleteComment" asp-route-threadId="@Model.Id" asp-route-commentId="@comment.Id" method="post" class="link-form">
                                                    <button type="submit" onclick="return confirm('Delete this comment?');">Delete</button>
                                                </form>
                                            </span>
                                        }
                                    }
                                </div>
                            }
                            <form asp-action="PostComment" asp-route-id="@Model.Id" asp-route-postId="@post.Id" method="post">
                                <textarea id="comment-content-@post.Id" name="content" class="form-control-sm" placeholder="Your comment..." style="margin-top: 8px;"></textarea>
                                <br/>
                                <button type="submit" class="btn btn-secondary btn-sm">Add comment</button>
                            </form>
                        </div>
                    </div>
                </article>
            }
        }

        @if (User.Identity?.IsAuthenticated == true)
        {
            <form asp-controller="Thread" asp-action="PostAnswer" asp-route-id="@Model.Id" method="post" class="answer-form">
                <h3>Your Answer</h3>
                @if (TempData["AnswerError"] is string answerError)
                {
                    <div class="text-danger answer-error">@answerError</div>
                }
                <div class="form-floating">
                    <textarea id="answer-content" name="content" class="form-control" placeholder="Enter your answer here..."></textarea>
                    <label for="answer-content">Answer</label>
                </div>

                <!-- Live preview for the answer content. Rendered client-side from triple-backtick fences. -->
                <div class="mt-3">
                    <h4 class="h6">Preview</h4>
                    <div id="answer-preview" class="card card-body" style="min-height: 6rem; white-space: pre-wrap;"></div>
                </div>

                <button type="submit" class="btn btn-primary" style="margin-top: 15px;">Post Your Answer</button>
            </form>
        }
    </section>
</section>
